<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_libro_tree" model="ir.ui.view">
        <field name="name">morenitapp.libro.tree</field>
        <field name="model">morenitapp.libro</field>
        <field name="arch" type="xml">
            <tree string="Libros">
                <field name="cod_libro"/>
                <field name="nombre"/>
                <field name="anio"/>
                <field name="total_anunciantes" sum="Total"/>
            </tree>
        </field>
    </record>

    <record id="view_libro_form" model="ir.ui.view">
        <field name="name">morenitapp.libro.form</field>
        <field name="model">morenitapp.libro</field>
        <field name="arch" type="xml">
            <form string="Libro">
                <sheet>
                    <group>
                        <group>
                            <field name="cod_libro"/>
                            <field name="nombre"/>
                            <field name="anio"/>
                        </group>
                        <group>
                            <field name="tipoevento_id"/>
                            <field name="importe"/>
                            <field name="fecha_recibo"/> </group>
                    </group>
                    <notebook>
                        <page string="Anunciantes">
                            <field name="anunciantes_ids">
                                <tree editable="bottom">
                                    <field name="proveedor_id"/>
                                    <field name="importe" sum="Total"/>
                                    <field name="cobrado"/>
                                    <field name="fecha_cobro"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_anunciantes" readonly="1"/>
                            </group>
                        </page>
                        <page string="Textos">
                            <group>
                                <field name="texto_recibo_evento"/>
                                <field name="texto_anunciante"/>
                            </group>
                        </page>
                        <page string="Adjuntos">
                            <field name="adjuntos_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>