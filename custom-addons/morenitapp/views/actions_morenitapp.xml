<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ====================== ACCIONES ====================== -->

    <!-- Dashboard -->
    <record id="action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">morenitapp.hermano</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- ====================== HERMANOS ====================== -->
    <record id="action_hermanos" model="ir.actions.act_window">
        <field name="name">Hermanos</field>
        <field name="res_model">morenitapp.hermano</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('fecha_baja','=',False)]</field>
    </record>

    <record id="action_hermanos_baja" model="ir.actions.act_window">
        <field name="name">Hermanos de Baja</field>
        <field name="res_model">morenitapp.hermano</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('fecha_baja','!=',False)]</field>
    </record>

