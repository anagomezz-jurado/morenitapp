<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= TREE ================= -->
    <record id="view_proveedor_tree" model="ir.ui.view">
        <field name="name">proveedor.tree</field>
        <field name="model">morenitapp.proveedor</field>
        <field name="arch" type="xml">
            <tree string="Proveedores">
                <field name="cod_proveedor"/>
                <field name="nombre"/>
                <field name="contacto"/>
                <field name="telefono"/>
                <field name="email"/>
                <field name="grupo_id"/>
                <field name="anunciante"/>
            </tree>
        </field>
    </record>

    <!-- ================= FORM ================= -->
    <record id="view_proveedor_form" model="ir.ui.view">
        <field name="name">proveedor.form</field>
        <field name="model">morenitapp.proveedor</field>
        <field name="arch" type="xml">
            <form string="Proveedor">
                <sheet>
                    <group>
                        <field name="cod_proveedor"/>
                        <field name="nombre"/>
                        <field name="anunciante"/>
                        <field name="grupo_id"/>
                    </group>
                    <group string="Contacto">
                        <field name="contacto"/>
                        <field name="telefono"/>
                        <field name="email"/>
                    </group>
                     <group string="Dirección">
                        <field name="calle_id"/>
                        <field name="localidad_id" readonly="1"/>
                        <field name="codPostal_id" readonly="1"/>   
                        <field name="provincia_id" readonly="1"/>
                        <field name="numero"/>
                        <field name="piso"/>
                        <field name="bloque"/>
                        <field name="escalera"/>
                        <field name="portal"/>
                        <field name="puerta"/>
                    </group>
                    <group string="Observaciones">
                        <field name="observaciones"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
</odoo>