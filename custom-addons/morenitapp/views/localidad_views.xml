<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<!-- TREE -->
<record id="view_localidad_tree" model="ir.ui.view">
    <field name="name">localidad.tree</field>
    <field name="model">morenitapp.localidad</field>
    <field name="arch" type="xml">
        <tree string="Localidades">
            <field name="nombreLocalidad"/>
            <field name="codProvincia_id"/>
            <field name="nombreCapital"/>
        </tree>
    </field>
</record>

<!-- FORM -->
<record id="view_localidad_form" model="ir.ui.view">
    <field name="name">localidad.form</field>
    <field name="model">morenitapp.localidad</field>
    <field name="arch" type="xml">
        <form string="Localidad">
            <sheet>
                <group>
                    <field name="nombreLocalidad"/>
                    <field name="codProvincia_id"/>
                    <field name="nombreCapital"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

</odoo>